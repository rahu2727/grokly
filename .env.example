# Grokly — API Keys
# Copy this file to .env and add your real keys

# Required — Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required — Tavily web search
TAVILY_API_KEY=tvly-your-key-here

# Optional — LangSmith tracing
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=grokly

# Development debugging
GROKLY_DEBUG=false
# Set to true to see proactive agent debug info in the UI

# ─────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────
# Global default — used when no agent-specific model is configured
GROKLY_DEFAULT_MODEL=claude-sonnet-4-20250514

# Override per agent (optional)
# Leave blank to use GROKLY_DEFAULT_MODEL
GROKLY_MODEL_COMMENTARY=claude-opus-4-20250514
GROKLY_MODEL_COUNSEL=claude-sonnet-4-20250514
GROKLY_MODEL_TRACKER=claude-haiku-4-5-20251001
GROKLY_MODEL_BRIEFER=claude-sonnet-4-20250514
GROKLY_MODEL_MEMORY=claude-haiku-4-5-20251001
GROKLY_MODEL_PROACTIVE=claude-haiku-4-5-20251001
GROKLY_MODEL_MONITOR=claude-haiku-4-5-20251001

# Future: non-Anthropic models (Sprint 6+)
# GROKLY_PROVIDER=anthropic
# GROKLY_MODEL_COUNSEL=gpt-4o
# GROKLY_OPENAI_API_KEY=sk-...
