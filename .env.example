# Grokly — API Keys
# Copy this file to .env and add your real keys

# Required — Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required — Tavily web search
TAVILY_API_KEY=tvly-your-key-here

# Optional — LangSmith tracing
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=grokly

# Development debugging
GROKLY_DEBUG=false
# Set to true to see proactive agent debug info in the UI
